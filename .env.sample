# All environment variables available for development
# Copy this to `tracker/.env` and edit values as needed, especically before running docker-compose and/or production use.
# DO NOT commit `.env.*` with real secrets.

# Docker Compose project name (used for container naming)
# Use a different name to distinguish from dev containers
COMPOSE_PROJECT_NAME=project-tracker-prod

# Django settings
DEBUG=True
LOCAL=True
DJANGO_SECRET_KEY=change-me-or-use-docker-secrets-or-env-vars-or-a-secrets-manager

# Other useful runtime options
PYTHONUNBUFFERED=1

# Database: for simple local dev we use sqlite3 by default.
# To use PostgreSQL locally, uncomment and edit the example below and set
# `DATABASE_URL` to point to the `postgres` service defined in
# `docker-compose.yml`.
#
# POSTGRES_DB=tracker
# POSTGRES_USER=tracker
# POSTGRES_PASSWORD=tracker
# DATABASE_URL=postgres://tracker:tracker@postgres:5432/tracker
DATABASE_URL=sqlite:///db.sqlite3

# Celery/Redis
CELERY_TASK_ALWAYS_EAGER=True  # Must be True for local development and tests, False will require Redis.
# CELERY_BROKER_URL=redis://redis:6379/0  # This points at Docker.
CELERY_LOG_LEVEL=INFO
# Optional: configure result backend if needed
# CELERY_RESULT_BACKEND=django-db+sqlite:///results.sqlite

# Redis (if you reference it directly)
# REDIS_HOST=redis
# REDIS_PORT=6379

# NGINX / Let's Encrypt (used by the nginx-proxy + acme override)
# Set `NGINX_HOST` to your domain and `LETSENCRYPT_EMAIL` to the contact email
# used for Let's Encrypt registration and expirations.
# NGINX_HOST=example.com
# LETSENCRYPT_EMAIL=ops@example.com

# Logging
LOG_LEVEL=INFO

# Sending Email
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=someone
# EMAIL_HOST_PASSWORD=change-me-or-use-docker-secrets-or-env-vars-or-a-secrets-manager
# EMAIL_USE_TLS=True


# Other runtime flags
# Example: FEATURE_FLAG_X=true

# Note about secrets:
# - This sample includes placeholder values for convenience. For sensitive
#   values (database password, Django SECRET_KEY) prefer Docker secrets or a
#   secrets manager (Vault, AWS Secrets Manager, etc.). The `docker-compose.prod.yml`
#   in this project demonstrates using files under `./secrets/` for Docker secrets.
