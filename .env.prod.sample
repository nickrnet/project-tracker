# Production environment sample. Copy to `.env.prod` and fill values.
# DO NOT commit `.env.prod` with real secrets.

# Docker Compose project name (used for container naming)
# Use a different name to distinguish from dev containers
COMPOSE_PROJECT_NAME=project-tracker-prod

# General Django
DEBUG=false
ALLOWED_HOSTS=.example.com

# Django settings module to use in containers
DJANGO_SETTINGS_MODULE=tracker.settings.production

# Database - prefer providing a full DATABASE_URL. Example below uses
# Postgres running in the compose stack.
DATABASE_URL=postgres://tracker:password@postgres:5432/tracker
POSTGRES_DB=tracker
POSTGRES_USER=tracker
# Prefer Docker secrets for production passwords rather than plaintext envs.

# Celery / Broker
CELERY_BROKER_URL=redis://redis:6379/0

# Redis (if you reference it directly)
REDIS_HOST=redis
REDIS_PORT=6379

# NGINX / Let's Encrypt (used by the nginx-proxy + acme override)
# Set `NGINX_HOST` to your domain and `LETSENCRYPT_EMAIL` to the contact email
# used for Let's Encrypt registration and expirations.
NGINX_HOST=example.com
LETSENCRYPT_EMAIL=ops@example.com

# Sentry / Monitoring (optional)
SENTRY_DSN=

# Storage (optional)
USE_S3=false
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Logging
LOG_LEVEL=INFO

# Other runtime flags
# Example: FEATURE_FLAG_X=true

# Note about secrets:
# - This sample includes placeholder values for convenience. For sensitive
#   values (database password, Django SECRET_KEY) prefer Docker secrets or a
#   secrets manager (Vault, AWS Secrets Manager, etc.). The `docker-compose.prod.yml`
#   in this project demonstrates using files under `./secrets/` for Docker secrets.