# Local environment variables for LOCAL development (without Docker)
# Copy this to `.env` if you want to develop without Docker containers

# Docker Compose project name (only used if running with Docker)
COMPOSE_PROJECT_NAME=project-tracker-local

DEBUG=True
LOCAL=True
DJANGO_SECRET_KEY=change-me-for-local

# Database: Use SQLite for local development
# Comment out DATABASE_URL to use default SQLite, or explicitly set it:
# DATABASE_URL=sqlite:///db.sqlite3

# Celery: Use eager mode for local development (runs tasks synchronously)
CELERY_TASK_ALWAYS_EAGER=True

# Other useful runtime options
PYTHONUNBUFFERED=1
